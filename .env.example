# Copy to .env and adjust as needed. Every variable is prefixed MVRAG_.
# Anything you don't set falls back to the defaults in src/mvrag/config.py.

MVRAG_DEVICE=cuda

# --- ASR (Whisper) ---
MVRAG_WHISPER_MODEL=large-v3
MVRAG_WHISPER_COMPUTE_TYPE=float16

# --- Embeddings ---
MVRAG_TEXT_EMBED_MODEL=BAAI/bge-m3

# --- Generation: pick a provider — ollama (default) | openai | anthropic ---
MVRAG_LLM_PROVIDER=ollama

# Local (Ollama)
MVRAG_OLLAMA_HOST=http://localhost:11434
MVRAG_OLLAMA_MODEL=qwen2.5:7b

# Cloud APIs (optional): `pip install -e ".[api]"`, set MVRAG_LLM_PROVIDER above, then:
# MVRAG_ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=sk-ant-...
# MVRAG_OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
